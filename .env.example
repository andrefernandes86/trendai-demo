# =============================================================================
# TrendAI Demo Platform — environment template
# Copy to `.env` and adjust. `.env` is gitignored.
#
#   cp .env.example .env
#   docker compose up -d --build
# =============================================================================

# --- Portal -----------------------------------------------------------------
# The portal always seeds admin / admin on first boot and forces a password
# change. Nothing to configure here unless you want to change the host port
# (edit docker-compose.yml -> portal.ports).
#
# Optional: serve every demo through one Cloudflare tunnel using a hostname per
# demo. Set this to your base domain and add matching Public Hostnames in the
# Cloudflare dashboard (v1fs.<domain>, appsec.<domain>, smish.<domain>,
# ai.<domain>). Leave unset to link demos by host:port instead.
# PORTAL_DEMO_DOMAIN=secnerd.io

# --- Smish Detector ---------------------------------------------------------
# Password required to view the captured-data report page.
REPORT_PASSWORD=sms

# --- V1 File Security Scanner ------------------------------------------------
# The Vision One File Security API key + region are entered in the tool's own
# Settings UI at runtime (persisted in its Docker volume). Nothing needed here.

# --- App & File Security -----------------------------------------------------
# Requires a Vision One File Security API key and (optionally) an Ollama host.
# These are consumed by the tool per its own README (tools/app-sec-file-sec).
# V1_FS_API_KEY=your-vision-one-file-security-key
# OLLAMA_HOST=http://your-ollama-host:11434

# --- AI Security (Health AI Assistant) stack --------------------------------
# The included stack needs an Ollama endpoint for AI features and a TMAS API
# key for the security scanner. Set these in the app's Settings UI at runtime,
# or edit tools/ai-security/docker-compose.yml for permanent values.
# OLLAMA_HOST=http://your-ollama-host:11434
# TMAS_API_KEY=your-tmas-api-key
