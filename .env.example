# =============================================================================
# TrendAI Demo Platform — environment template
# Copy to `.env` and adjust. `.env` is gitignored.
#
#   cp .env.example .env
#   docker compose up -d --build
# =============================================================================

# --- Portal -----------------------------------------------------------------
# The portal always seeds admin / admin on first boot and forces a password
# change. It reverse-proxies every demo behind that login, so nothing else here
# is required. To change the published port, edit docker-compose.yml
# (portal.ports).

# --- Smish Detector ---------------------------------------------------------
# Password required to view the captured-data report page.
REPORT_PASSWORD=sms

# --- V1 File Security Scanner ------------------------------------------------
# The Vision One File Security API key + region are entered in the tool's own
# Settings UI at runtime (persisted in its Docker volume). Nothing needed here.

# --- AI Guard & File Security (chatbot) + Ollama -----------------------------
# A bundled Ollama container serves a small CPU model for the chatbot and is
# pre-wired at http://ollama:11434. Change the model here (pulled on first
# start). llama3.2:1b is faster on CPU; gemma2:2b is the default.
OLLAMA_MODEL=gemma2:2b
# TrendAI Vision One API keys for the two detection modules are entered in the
# app's Settings UI at runtime (no secrets in files).
